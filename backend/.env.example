# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-key-here

# WhatsApp Cloud API Configuration
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_VERIFY_TOKEN=your-custom-verify-token
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id

# WhatsApp Template Names (must match approved templates in Meta)
WHATSAPP_TEMPLATE_NAME_EN=daily_exercise_update
WHATSAPP_TEMPLATE_NAME_ES=actualizacion_sesion_diaria
WHATSAPP_REMINDER_TEMPLATE_NAME_EN=weekly_exercise_reminder
WHATSAPP_REMINDER_TEMPLATE_NAME_ES=sesion_ejercicio_semanal

# Vercel Cron Authentication
CRON_SECRET=your-cron-secret

# Server Configuration
PORT=3000
NODE_ENV=development

# Timezone Configuration
SEND_TIME_HOUR=9
SEND_TIME_TIMEZONE=America/New_York

# Admin Alerts (optional)
ADMIN_PHONE_NUMBER=             # WhatsApp number to receive cron failure alerts (e.g. +13055629885)

# Message Display
SEND_TIME_DISPLAY=9 AM EST      # Time string shown in messages to seniors

# Workout Mode (image-based programs)
USE_WORKOUT_IMAGES=false        # Set to 'true' to switch from YouTube videos to image workouts

# Analytics
POSTHOG_API_KEY=                # PostHog project API key (phc_...) — free at posthog.com
